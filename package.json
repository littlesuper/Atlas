{
  "name": "hwsystem",
  "version": "1.1.20",
  "description": "贝锐硬件管理系统",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "audit": "npm audit --audit-level=high",
    "outdated": "npm outdated",
    "test:env": "docker compose -f docker-compose.test.yml up --build",
    "test:env:up": "docker compose -f docker-compose.test.yml up --build -d",
    "test:env:down": "docker compose -f docker-compose.test.yml down --remove-orphans",
    "test:env:logs": "docker compose -f docker-compose.test.yml logs -f atlas-test",
    "test:env:start": "sh scripts/test-env-start.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "overrides": {
    "@types/express": "4.17.25",
    "@types/express-serve-static-core": "4.19.8"
  },
  "lint-staged": {
    "client/src/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "server/src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9.0.0"
  }
}
