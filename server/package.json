{
  "name": "server",
  "version": "1.0.0",
  "description": "HWSystem Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "echo 'server uses tsx runtime, no build step'",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:integration": "vitest run src/__tests__/integration",
    "test:coverage": "vitest run --coverage.enabled",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^10.51.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pinyin-pro": "^3.28.0",
    "prom-client": "^15.1.3",
    "read-excel-file": "^9.0.6",
    "sanitize-html": "^2.17.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.19.2",
    "unleash-client": "^6.10.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.25",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.1.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
