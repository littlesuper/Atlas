# ==================== Atlas 生产环境配置 ====================
# deploy.sh setup 会自动生成此文件，通常不需要手动编辑
# 如需手动创建：复制此文件为 .env 并修改

NODE_ENV=production
PORT=3000

# 数据库（SQLite，自动创建）
DATABASE_URL=file:./data/atlas.db

# JWT 密钥（必改，用 openssl rand -hex 32 生成）
JWT_SECRET=请替换为随机密钥
JWT_REFRESH_SECRET=请替换为另一个随机密钥

# 允许访问的前端域名（必改）
# 局域网示例：http://192.168.1.100:3000
CORS_ORIGINS=http://你的服务器IP:3000

# AI 功能（可选）
AI_API_KEY=
AI_API_URL=

# 定时风险评估（可选）
RISK_SCHEDULER_ENABLED=false
RISK_SCHEDULER_CRON=0 8 * * 1-5
