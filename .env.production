# ==================== Atlas 生产环境配置 ====================
# 复制此文件为 .env 并修改下面的值

# 数据库密码（必改）
DB_PASSWORD=请替换为安全的随机密码

# JWT 密钥（必改，可用 openssl rand -hex 32 生成）
JWT_SECRET=请替换为随机密钥
JWT_REFRESH_SECRET=请替换为另一个随机密钥

# 允许访问的前端域名（必改，逗号分隔）
# 局域网示例：http://192.168.1.100:3000
# 域名示例：https://atlas.yourcompany.com
CORS_ORIGINS=http://你的服务器IP:3000

# 服务端口（默认 3000）
PORT=3000

# AI 功能（可选，不配则用规则引擎）
AI_API_KEY=
AI_API_URL=

# 定时风险评估（可选）
RISK_SCHEDULER_ENABLED=false
RISK_SCHEDULER_CRON=0 8 * * 1-5
